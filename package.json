{
  "name": "@mondrakebr1/rag-skills",
  "version": "1.0.9",
  "bin": {
    "rag-skills": "./dist/index.js",
    "specskill": "./dist/cli/index.js"
  },
  "description": "RAG-powered skills retrieval system",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "README.md",
    ".rag/",
    "specskill/",
    ".windsurf/workflows/",
    "scripts/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "rag": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "postinstall": "tsx scripts/postinstall/index.ts",
    "specskill:new": "tsx src/cli/index.ts new change",
    "specskill:status": "tsx src/cli/index.ts status",
    "specskill:list": "tsx src/cli/index.ts list",
    "specskill:instructions": "tsx src/cli/index.ts instructions",
    "specskill:apply": "tsx src/cli/index.ts apply",
    "specskill:continue": "tsx src/cli/index.ts continue",
    "specskill:archive": "tsx src/cli/index.ts archive",
    "specskill:exists": "tsx src/cli/index.ts exists",
    "specskill:generate": "tsx src/cli/index.ts generate",
    "build:cli": "tsc -p tsconfig.cli.json || tsc src/cli/index.ts --outDir dist/cli --module esnext --moduleResolution node --esModuleInterop true --target es2022"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luansilvadb/agoravai.git"
  },
  "keywords": [
    "rag",
    "skills",
    "embeddings",
    "typescript",
    "clean-architecture"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/luansilvadb/agoravai/issues"
  },
  "homepage": "https://github.com/luansilvadb/agoravai#readme",
  "dependencies": {
    "@mondrakebr1/rag-skills": "^1.0.0",
    "@xenova/transformers": "^2.17.2",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
