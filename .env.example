# PDV System - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# SECURITY - REQUIRED
# ============================================

# Session/CSRF Token Secret (generate a strong random string)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here_min_32_chars

# CSRF Token Secret (should be different from SESSION_SECRET)
CSRF_SECRET=your_csrf_secret_here_min_32_chars

# ============================================
# API & BACKEND (if applicable)
# ============================================

# API Base URL
API_BASE_URL=http://localhost:3000

# API Key for external services
API_KEY=your_api_key_here

# ============================================
# RATE LIMITING CONFIGURATION
# ============================================

# General API requests (requests per 15 minutes)
RATE_LIMIT_GENERAL=100

# Search endpoint (requests per minute)
RATE_LIMIT_SEARCH=10

# Payment endpoint (requests per minute) - more restrictive
RATE_LIMIT_PAYMENT=5

# ============================================
# UPLOAD CONFIGURATION
# ============================================

# Max file upload size in bytes (5MB default)
MAX_FILE_SIZE=5242880

# Allowed file extensions (comma-separated)
ALLOWED_FILE_TYPES=jpg,png,gif

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable POS Premium features
ENABLE_POS_PREMIUM=false

# Enable security report-only mode (for CSP testing)
SECURITY_REPORT_ONLY=false

# ============================================
# ENVIRONMENT
# ============================================

# Environment: development, staging, production
NODE_ENV=development

# Enable detailed error messages (disable in production)
DEBUG_ERRORS=true
