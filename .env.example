# Diretório de skills para escanear
SKILLS_DIR=.rag/context

# Arquivo de saída consolidado
OUTPUT_FILE=.rag/research/skills.md

# Threshold de similaridade (0 a 1)
SIMILARITY_THRESHOLD=0.3

# Quantidade de resultados top
TOP_K_RESULTS=3

# Nível de logging (debug, info, warn, error)
LOG_LEVEL=info

# Modelo de embeddings (Xenova)
MODEL_NAME=Xenova/paraphrase-multilingual-MiniLM-L12-v2
